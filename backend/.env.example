PORT=3001
NODE_ENV=development

# PostgreSQL — use Supabase, Railway, or local
DATABASE_URL=postgresql://postgres:password@localhost:5432/hoa_platform

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Stripe — get from stripe.com/docs/keys
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# SendGrid — get from app.sendgrid.com
SENDGRID_API_KEY=SG.replace_me
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=HOAConnect

# Twilio SMS — get from console.twilio.com
TWILIO_ACCOUNT_SID=AC_replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_FROM_NUMBER=+1replace_me

# Lob physical mail — get from lob.com
LOB_API_KEY=replace_me

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
